PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://mymedsense.co,https://www.mymedsense.co
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=medsense123
DB_NAME=medsense
DEFAULT_COUNTRY_CODE=254

# Gmail / SMTP email notifications.
# For Gmail, use a Google App Password, not your normal Gmail password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_digit_google_app_password
EMAIL_FROM=MedSense <your_gmail_address@gmail.com>

# WhatsApp Cloud API notifications.
# Create these in Meta Developers > WhatsApp > API Setup.
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_TOKEN=your_meta_whatsapp_access_token

# Optional: use an approved template instead of a free-form text message.
# The template body should accept:
# 1. patient name
# 2. medicine name
# 3. patient dashboard link
# WHATSAPP_TEMPLATE_NAME=medsense_review_ready
# WHATSAPP_TEMPLATE_LANGUAGE=en_US
